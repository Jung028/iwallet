<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Example bean declaration -->
    <bean id="testCustomDao" class="com.alipay.alipay_plus.common.service.facade.daoimpl.TestCustomDaoImpl">
        <property name="testCustomMapper" ref="testCustomMapper"/>
    </bean>

    <!-- Mapper bean -->
    <bean id="testCustomMapper" class="org.mybatis.spring.mapper.MapperFactoryBean">
        <property name="mapperInterface" value="com.alipay.alipay_plus.common.service.facade.auto.daointerface.TestCustomMapper"/>
        <!-- If using SqlSessionFactory, add below -->
        <!-- <property name="sqlSessionFactory" ref="sqlSessionFactory"/> -->
    </bean>

</beans>
